{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "sector-scan-v1",
  "title": "Sector Intelligence Scan",
  "description": "Structured data output for a sector intelligence briefing. The human-readable report is rendered from this data. Other agents consume this directly.",

  "type": "object",
  "required": ["meta", "sections", "evidenceQuality"],

  "properties": {

    "meta": {
      "description": "Report metadata — when it was built, what sector, depth mode used",
      "type": "object",
      "required": ["sectorName", "generatedAt", "generatedBy", "version", "depthMode"],
      "properties": {
        "sectorName":       { "type": "string", "description": "Sector or market segment, e.g. Defence IT, Local Government Digital" },
        "slug":             { "type": "string", "description": "URL-safe identifier, e.g. defence-it" },
        "scope":            { "type": "string", "enum": ["standalone", "bid_specific"], "description": "Whether this is a general sector scan or tailored for a specific pursuit" },
        "pursuitReference": { "type": "string", "description": "If bid-specific, the pursuit this scan supports" },
        "periodCovered":    { "type": "string", "description": "Date range of intelligence, e.g. April 2025 – April 2026" },
        "generatedAt":      { "type": "string", "format": "date-time" },
        "generatedBy":      { "type": "string", "description": "Who or what produced this scan" },
        "version":          { "type": "string", "description": "Scan version, e.g. 1.0, 1.1" },
        "depthMode":        { "type": "string", "enum": ["snapshot", "standard", "deep"], "description": "Depth mode used for this run" },
        "refreshedFrom":    { "type": "string", "description": "If this is a refresh, the version it built on" },
        "versionLog": {
          "type": "array",
          "description": "What changed in each version — most recent first",
          "items": {
            "type": "object",
            "properties": {
              "version":    { "type": "string" },
              "date":       { "type": "string", "format": "date" },
              "summary":    { "type": "string" }
            }
          }
        }
      }
    },

    "sections": {
      "description": "The six sections of a sector scan — each has narrative and structured data",
      "type": "object",
      "properties": {
        "policyAndRegulatory":      { "$ref": "#/$defs/scanSection" },
        "spendingAndBudget":        { "$ref": "#/$defs/scanSection" },
        "marketTrends":             { "$ref": "#/$defs/scanSection" },
        "tradePressAndCommentary":  { "$ref": "#/$defs/scanSection" },
        "peerComparisons":          { "$ref": "#/$defs/scanSection" },
        "implications":             { "$ref": "#/$defs/scanSection" }
      }
    },

    "policyDrivers": {
      "description": "Structured policy data — machine-readable for strategy and positioning",
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name":           { "type": "string", "description": "Policy, regulation, or strategy document name" },
          "type":           { "type": "string", "enum": ["legislation", "regulation", "guidance", "strategy", "spending_review", "white_paper", "green_paper", "other"] },
          "status":         { "type": "string", "enum": ["enacted", "proposed", "consultation", "announced", "expired"] },
          "impactOnSector": { "type": "string", "description": "How this affects procurement and delivery in this sector" },
          "implicationForBid": { "type": "string", "description": "What this means for bid positioning — if bid-specific" },
          "effectiveDate":  { "type": "string", "format": "date" },
          "source":         { "type": "string" },
          "confidence":     { "type": "number", "minimum": 0, "maximum": 100 }
        }
      }
    },

    "spendingSignals": {
      "description": "Structured spending and budget data",
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "signal":         { "type": "string", "description": "The spending commitment or budget allocation" },
          "value":          { "type": "string", "description": "GBP amount if stated" },
          "period":         { "type": "string", "description": "Financial year or spending review period" },
          "source":         { "type": "string" },
          "confidence":     { "type": "number", "minimum": 0, "maximum": 100 }
        }
      }
    },

    "frameworks": {
      "description": "Major frameworks in this sector — for route-to-market analysis",
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name":           { "type": "string" },
          "provider":       { "type": "string", "description": "e.g. CCS, NHS SBS, YPO" },
          "status":         { "type": "string", "enum": ["live", "expiring", "pipeline", "expired"] },
          "endDate":        { "type": "string", "format": "date" },
          "reLetTimeline":  { "type": "string", "description": "Expected re-competition timeline if known" },
          "lots":           { "type": "array", "items": { "type": "string" }, "description": "Lot names/numbers relevant to this sector" },
          "estimatedValue": { "type": "string", "description": "Total framework value if published" }
        }
      }
    },

    "marketTrends": {
      "description": "Structured trend data for AI consumption",
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "trend":          { "type": "string", "description": "The trend in one sentence" },
          "category":       { "type": "string", "enum": ["technology", "delivery_model", "workforce", "commercial", "regulatory", "other"] },
          "direction":      { "type": "string", "enum": ["accelerating", "stable", "emerging", "declining"] },
          "evidence":       { "type": "string", "description": "Source citation" },
          "bidImplication":  { "type": "string", "description": "What this means for positioning — if bid-specific" },
          "confidence":     { "type": "number", "minimum": 0, "maximum": 100 }
        }
      }
    },

    "intelligenceGaps": {
      "description": "What could not be determined",
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "gap":              { "type": "string" },
          "impact":           { "type": "string" },
          "recommendedAction": { "type": "string" }
        }
      }
    },

    "evidenceQuality": {
      "description": "Overall assessment of how much to trust this scan",
      "type": "object",
      "properties": {
        "totalCitations":     { "type": "number" },
        "tierDistribution": {
          "type": "object",
          "properties": {
            "tier1": { "type": "number" },
            "tier2": { "type": "number" },
            "tier3": { "type": "number" },
            "tier4": { "type": "number" },
            "tier5": { "type": "number" },
            "tier6": { "type": "number" }
          }
        },
        "averageConfidence":  { "type": "number" },
        "knownGaps":          { "type": "array", "items": { "type": "string" } }
      }
    },

    "linkedAssets": {
      "description": "Cross-references to related library assets",
      "type": "object",
      "properties": {
        "supplierDossiers": {
          "type": "array",
          "description": "Supplier dossiers for companies operating in this sector",
          "items": { "type": "string" }
        },
        "clientProfiles": {
          "type": "array",
          "description": "Client profiles for buyers in this sector",
          "items": { "type": "string" }
        },
        "pipelineScans": {
          "type": "array",
          "description": "Pipeline scans covering this sector",
          "items": { "type": "string" }
        }
      }
    }
  },

  "$defs": {
    "scanSection": {
      "type": "object",
      "description": "One section of the sector scan — narrative for the report, structured data for AI consumption",
      "required": ["headline", "narrative"],
      "properties": {
        "headline":     { "type": "string", "description": "One-sentence finding — the most important thing about this section" },
        "narrative":    { "type": "string", "description": "Detailed analysis in markdown — evidence-backed prose for the printed report" },
        "keyFacts": {
          "type": "array",
          "description": "Structured data points for AI consumption",
          "items": {
            "type": "object",
            "properties": {
              "label":      { "type": "string" },
              "value":      { "type": "string" },
              "confidence": { "type": "number", "minimum": 0, "maximum": 100 },
              "source":     { "type": "string" }
            }
          }
        },
        "gaps": {
          "type": "array",
          "description": "What could not be found for this section",
          "items": { "type": "string" }
        }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "client-operating-context-v1.1",
  "title": "Client Operating Context",
  "description": "Master operating-truth document for a paying customer of the PWIN platform. Not a biography. The structured context the AI reasons FROM when producing qualification, win strategy, positioning, and pursuit recommendations for this specific client. V1.1 adds the three pursuit-reality domains (bid operating model, delivery mobilisation, culture/decision style) that V1 deferred. Claim-typing, governance, and decay are day-one requirements — not optional polish.",
  "type": "object",
  "required": [
    "clientContextId",
    "clientName",
    "profileType",
    "version",
    "governance",
    "identity",
    "strategicObjectives",
    "commercialProfile",
    "capabilityMap",
    "differentiation",
    "pursuitPreferences",
    "historicPerformance",
    "riskGuardrails",
    "bidOperatingModel",
    "deliveryMobilisation",
    "cultureDecisionStyle",
    "sources"
  ],
  "properties": {
    "clientContextId": { "type": "string", "description": "Stable internal ID, e.g. client-bip-uk-001" },
    "clientName": { "type": "string" },
    "profileType": {
      "type": "string",
      "const": "paying_customer_master_context",
      "description": "Distinguishes this from buyer/supplier/sector profiles"
    },
    "version": { "type": "string", "description": "Semantic version of this document" },
    "status": { "type": "string", "enum": ["draft", "active", "under_review", "archived"] },

    "governance": {
      "type": "object",
      "required": ["owner", "updatedAt", "nextReviewDueAt", "overallConfidence", "approvedForAiUse"],
      "properties": {
        "owner": { "type": "string", "description": "Engagement lead responsible for keeping this current" },
        "contributors": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "lastReviewedAt": { "type": "string", "format": "date-time" },
        "nextReviewDueAt": { "type": "string", "format": "date-time", "description": "Hard decay date — after this, AI should flag context as stale" },
        "overallConfidence": { "$ref": "#/$defs/confidence" },
        "completenessScore": { "type": "number", "minimum": 0, "maximum": 1 },
        "freshnessScore": { "type": "number", "minimum": 0, "maximum": 1 },
        "confidentiality": { "type": "string", "enum": ["internal", "client_confidential", "restricted"] },
        "approvedForAiUse": { "type": "boolean", "description": "If false, downstream skills must not consume this document" }
      }
    },

    "identity": {
      "type": "object",
      "description": "Who the client is commercially and operationally",
      "required": ["legalEntityName", "businessModelCategory", "businessModel", "sectorsServed", "serviceLines"],
      "properties": {
        "legalEntityName": { "type": "string" },
        "tradingNames": { "type": "array", "items": { "type": "string" } },
        "parentGroup": { "type": "string" },
        "ownershipModel": { "$ref": "#/$defs/claim" },
        "hqLocation": { "type": "string" },
        "deliveryGeographies": { "type": "array", "items": { "type": "string" } },
        "businessModelCategory": {
          "allOf": [
            { "$ref": "#/$defs/claim" },
            {
              "properties": {
                "dominant": {
                  "type": "string",
                  "enum": ["management_consulting", "systems_integration", "managed_services", "reseller", "product_platform", "blended"]
                },
                "emerging": {
                  "type": "string",
                  "enum": ["management_consulting", "systems_integration", "managed_services", "reseller", "product_platform", "none"]
                }
              },
              "required": ["dominant"]
            }
          ],
          "description": "Categorical anchor — every downstream claim is interpreted against this frame. Free-text narrative lives in businessModel."
        },
        "businessModel": { "$ref": "#/$defs/claim" },
        "size": {
          "type": "object",
          "properties": {
            "fteEstimate": { "type": "integer" },
            "revenueEstimateGbp": { "type": "number" },
            "claimType": { "$ref": "#/$defs/claimType" },
            "confidence": { "$ref": "#/$defs/confidence" },
            "sources": { "$ref": "#/$defs/sourceRefs" }
          }
        },
        "sectorsServed": { "type": "array", "items": { "type": "string" } },
        "serviceLines": { "type": "array", "items": { "type": "string" } }
      }
    },

    "strategicObjectives": {
      "type": "object",
      "description": "What the client is trying to achieve — the yardstick for pursuit fit",
      "properties": {
        "growthPriorities": { "type": "array", "items": { "$ref": "#/$defs/claim" } },
        "prioritySectors": {
          "type": "array",
          "items": {
            "allOf": [
              { "$ref": "#/$defs/claim" },
              {
                "properties": {
                  "sector": { "type": "string" },
                  "priorityLevel": { "$ref": "#/$defs/priorityLevel" }
                },
                "required": ["sector", "priorityLevel"]
              }
            ]
          }
        },
        "targetContractValueBands": {
          "type": "array",
          "items": {
            "allOf": [
              { "$ref": "#/$defs/claim" },
              {
                "properties": {
                  "minGbp": { "type": "number" },
                  "maxGbp": { "type": "number" }
                }
              }
            ]
          }
        },
        "strategicTensions": {
          "type": "array",
          "items": { "$ref": "#/$defs/claim" },
          "description": "Genuine contradictions the AI must respect, not flatten"
        }
      }
    },

    "commercialProfile": {
      "type": "object",
      "description": "Realistic commercial envelope — stops the AI recommending deals the client shouldn't touch",
      "properties": {
        "preferredRoles": {
          "type": "array",
          "items": {
            "allOf": [
              { "$ref": "#/$defs/claim" },
              {
                "properties": {
                  "role": { "type": "string", "enum": ["prime_contractor", "subcontractor", "consortium_lead", "consortium_member", "sme_specialist"] },
                  "priorityLevel": { "$ref": "#/$defs/priorityLevel" }
                },
                "required": ["role"]
              }
            ]
          }
        },
        "pricingPreferences": {
          "type": "array",
          "items": {
            "allOf": [
              { "$ref": "#/$defs/claim" },
              {
                "properties": {
                  "model": { "type": "string", "enum": ["time_and_materials", "fixed_price", "outcome_based", "capped_tm", "framework_rate_card", "other"] },
                  "preferenceLevel": { "$ref": "#/$defs/priorityLevel" }
                },
                "required": ["model"]
              }
            ]
          }
        },
        "marginExpectations": {
          "type": "object",
          "properties": {
            "targetGrossMarginPct": { "type": "number" },
            "marginFloorPct": { "type": "number" },
            "claimType": { "$ref": "#/$defs/claimType" },
            "confidence": { "$ref": "#/$defs/confidence" },
            "sources": { "$ref": "#/$defs/sourceRefs" }
          }
        },
        "riskTolerance": {
          "type": "array",
          "items": {
            "allOf": [
              { "$ref": "#/$defs/claim" },
              {
                "properties": {
                  "riskArea": { "type": "string" },
                  "tolerance": { "type": "string", "enum": ["high", "medium", "low", "none"] }
                },
                "required": ["riskArea", "tolerance"]
              }
            ]
          }
        },
        "bidCostTolerance": {
          "type": "object",
          "properties": {
            "minGbp": { "type": "number" },
            "maxGbp": { "type": "number" },
            "claimType": { "$ref": "#/$defs/claimType" },
            "confidence": { "$ref": "#/$defs/confidence" },
            "sources": { "$ref": "#/$defs/sourceRefs" }
          }
        }
      }
    },

    "capabilityMap": {
      "type": "object",
      "description": "What the client can actually sell and deliver — defines strike zone",
      "properties": {
        "coreCapabilities": { "type": "array", "items": { "$ref": "#/$defs/capabilityEntry" } },
        "adjacentCapabilities": { "type": "array", "items": { "$ref": "#/$defs/capabilityEntry" } },
        "emergingCapabilities": { "type": "array", "items": { "$ref": "#/$defs/capabilityEntry" } },
        "avoidZones": {
          "type": "array",
          "items": {
            "allOf": [
              { "$ref": "#/$defs/claim" },
              {
                "properties": {
                  "name": { "type": "string" },
                  "reason": { "type": "string" }
                },
                "required": ["name", "reason"]
              }
            ]
          }
        },
        "methodsIpAccelerators": {
          "type": "array",
          "items": {
            "allOf": [
              { "$ref": "#/$defs/claim" },
              {
                "properties": {
                  "name": { "type": "string" },
                  "type": { "type": "string", "enum": ["methodology", "ip_asset", "accelerator", "platform", "tool"] },
                  "strengthLevel": { "$ref": "#/$defs/strengthLevel" }
                },
                "required": ["name"]
              }
            ]
          }
        },
        "accreditations": {
          "type": "array",
          "items": {
            "allOf": [
              { "$ref": "#/$defs/claim" },
              {
                "properties": {
                  "name": { "type": "string" },
                  "status": { "type": "string", "enum": ["held", "in_progress", "expired", "not_held"] },
                  "expiresAt": { "type": "string", "format": "date" }
                },
                "required": ["name", "status"]
              }
            ]
          }
        },
        "capacityConstraints": { "type": "array", "items": { "$ref": "#/$defs/claim" } }
      }
    },

    "differentiation": {
      "type": "object",
      "description": "What the AI is allowed to position as distinctive — and what not to overclaim",
      "properties": {
        "trueDifferentiators": { "type": "array", "items": { "$ref": "#/$defs/claim" } },
        "tableStakes": { "type": "array", "items": { "$ref": "#/$defs/claim" } },
        "doNotOverclaim": {
          "type": "array",
          "items": { "$ref": "#/$defs/claim" },
          "description": "Often more valuable than the strengths — encodes the AI's guardrails"
        },
        "proofPoints": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["proofId", "title", "usableExternally", "claimType", "confidence"],
            "properties": {
              "proofId": { "type": "string" },
              "title": { "type": "string" },
              "sector": { "type": "string" },
              "capabilityTags": { "type": "array", "items": { "type": "string" } },
              "outcomeMetric": { "type": "string" },
              "usableExternally": { "type": "boolean" },
              "approvalStatus": { "type": "string", "enum": ["approved", "pending", "restricted", "do_not_use"] },
              "recency": { "type": "string", "enum": ["current", "recent", "dated", "historic"], "description": "current: <12mo. recent: 12-24mo. dated: 24-48mo. historic: >48mo." },
              "buyerTrustLevel": { "type": "string", "enum": ["high", "medium", "low", "untested"], "description": "How much weight does this proof carry with the target buyer segment" },
              "namedVsAnonymised": { "type": "string", "enum": ["named", "anonymised", "restricted_named"] },
              "deliveryDate": { "type": "string", "format": "date" },
              "claimType": { "$ref": "#/$defs/claimType" },
              "confidence": { "$ref": "#/$defs/confidence" },
              "sources": { "$ref": "#/$defs/sourceRefs" }
            }
          }
        }
      }
    },

    "pursuitPreferences": {
      "type": "object",
      "description": "What good work looks like for this client — the AI's qualification anchor",
      "properties": {
        "preferredBuyers": {
          "type": "array",
          "items": {
            "allOf": [
              { "$ref": "#/$defs/claim" },
              {
                "properties": {
                  "buyerType": { "type": "string" },
                  "priorityLevel": { "$ref": "#/$defs/priorityLevel" }
                },
                "required": ["buyerType"]
              }
            ]
          }
        },
        "preferredRoutesToMarket": {
          "type": "array",
          "items": {
            "allOf": [
              { "$ref": "#/$defs/claim" },
              {
                "properties": {
                  "route": { "type": "string", "enum": ["framework_calloff", "open_tender", "direct_award", "competitive_dialogue", "negotiated", "prior_information_notice", "dps_calloff", "other"] },
                  "priorityLevel": { "$ref": "#/$defs/priorityLevel" },
                  "formalAccess": { "type": "boolean", "description": "Holds the framework / has eligibility" },
                  "practicalAccess": { "type": "string", "enum": ["strong", "weak", "none"], "description": "Can the client actually exploit the route — relationships, named positions, call-off history" },
                  "historicUsageCount": { "type": "integer", "description": "Number of bids via this route in the last 24 months" },
                  "winRatePct": { "type": "number", "minimum": 0, "maximum": 100 },
                  "accessNotes": { "type": "string" }
                },
                "required": ["route"]
              }
            ]
          }
        },
        "preferredDealArchetypes": {
          "type": "array",
          "items": {
            "allOf": [
              { "$ref": "#/$defs/claim" },
              {
                "properties": {
                  "archetype": { "type": "string" },
                  "priorityLevel": { "$ref": "#/$defs/priorityLevel" }
                },
                "required": ["archetype"]
              }
            ]
          }
        },
        "avoidArchetypes": {
          "type": "array",
          "items": {
            "allOf": [
              { "$ref": "#/$defs/claim" },
              {
                "properties": {
                  "archetype": { "type": "string" },
                  "reason": { "type": "string" }
                },
                "required": ["archetype", "reason"]
              }
            ]
          }
        },
        "noGoTriggers": {
          "type": "array",
          "description": "Hard disqualifiers — if present in a pursuit, the AI must recommend no-bid",
          "items": {
            "type": "object",
            "required": ["trigger", "severity"],
            "properties": {
              "trigger": { "type": "string" },
              "severity": { "type": "string", "enum": ["high", "medium", "low"] },
              "rationale": { "type": "string" }
            }
          }
        }
      }
    },

    "historicPerformance": {
      "type": "object",
      "description": "How this client has actually performed — where client-specific prediction becomes credible",
      "properties": {
        "winLossPatterns": { "type": "array", "items": { "$ref": "#/$defs/claim" } },
        "commonLossReasons": {
          "type": "array",
          "items": {
            "allOf": [
              { "$ref": "#/$defs/claim" },
              {
                "properties": {
                  "reason": { "type": "string" },
                  "frequency": { "type": "string", "enum": ["high", "medium", "low"] }
                },
                "required": ["reason"]
              }
            ]
          }
        },
        "commonWinThemes": { "type": "array", "items": { "$ref": "#/$defs/claim" } },
        "badWinPatterns": {
          "type": "array",
          "items": { "$ref": "#/$defs/claim" },
          "description": "Wins that eroded margin, damaged reputation, or consumed capacity disproportionately"
        },
        "shouldHaveNoBidPatterns": { "type": "array", "items": { "$ref": "#/$defs/claim" } }
      }
    },

    "riskGuardrails": {
      "type": "object",
      "description": "What the client will not tolerate — prevents reckless AI recommendations",
      "properties": {
        "marginFloorPct": { "type": "number" },
        "capabilityStretchTolerance": { "type": "string", "enum": ["high", "medium", "low", "none"] },
        "partnerDependencyTolerance": { "type": "string", "enum": ["high", "medium", "low", "none"] },
        "redLines": {
          "type": "array",
          "items": { "$ref": "#/$defs/claim" },
          "description": "Absolute prohibitions — commercial, reputational, regulatory, or capability-based"
        },
        "approvalThresholds": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["scenario", "approver"],
            "properties": {
              "scenario": { "type": "string" },
              "thresholdGbp": { "type": "number" },
              "approver": { "type": "string" }
            }
          }
        }
      }
    },

    "bidOperatingModel": {
      "type": "object",
      "description": "How the client actually pursues work — where the real bottlenecks sit, not the process map. Distinguishes firms that capture early from firms that react at ITT.",
      "properties": {
        "captureMaturity": {
          "allOf": [
            { "$ref": "#/$defs/claim" },
            {
              "properties": {
                "level": { "type": "string", "enum": ["absent", "reactive", "emerging", "disciplined", "optimised"] },
                "rationale": { "type": "string" }
              },
              "required": ["level"]
            }
          ]
        },
        "governanceStages": {
          "type": "array",
          "items": {
            "allOf": [
              { "$ref": "#/$defs/claim" },
              {
                "properties": {
                  "gate": { "type": "string", "description": "e.g. qualification, solution lock, price lock, sign-off" },
                  "approver": { "type": "string" },
                  "typicalDurationDays": { "type": "number" },
                  "isBottleneck": { "type": "boolean" }
                },
                "required": ["gate"]
              }
            ]
          }
        },
        "approvalBottlenecks": {
          "type": "array",
          "items": {
            "allOf": [
              { "$ref": "#/$defs/claim" },
              {
                "properties": {
                  "area": { "type": "string", "enum": ["pricing", "legal", "solution", "commercial_terms", "executive_signoff", "partner_onboarding", "other"] },
                  "description": { "type": "string" },
                  "severity": { "type": "string", "enum": ["high", "medium", "low"] }
                },
                "required": ["area", "severity"]
              }
            ]
          }
        },
        "executiveEngagementModel": {
          "allOf": [
            { "$ref": "#/$defs/claim" },
            {
              "properties": {
                "pattern": { "type": "string", "enum": ["hands_on", "ceremonial", "late_stage_only", "absent", "deal_dependent"] }
              },
              "required": ["pattern"]
            }
          ]
        },
        "commonFailureModes": {
          "type": "array",
          "items": { "$ref": "#/$defs/claim" },
          "description": "Recurring ways the client's own bid process undermines good bids — late partner engagement, unresolved solution at price-lock, legal deviations raised post-submission, etc."
        },
        "partnerOnboardingModel": {
          "allOf": [
            { "$ref": "#/$defs/claim" },
            {
              "properties": {
                "speed": { "type": "string", "enum": ["fast", "moderate", "slow", "blocker"] },
                "description": { "type": "string" }
              }
            }
          ]
        }
      }
    },

    "deliveryMobilisation": {
      "type": "object",
      "description": "Can the client actually land what it proposes. Feeds go/no-go directly — a strong proposal plus weak mobilisation is still a loss risk.",
      "properties": {
        "deliveryModel": {
          "allOf": [
            { "$ref": "#/$defs/claim" },
            {
              "properties": {
                "shape": { "type": "string", "enum": ["onshore", "offshore", "hybrid", "partner_led", "associate_led", "mixed"] },
                "description": { "type": "string" }
              }
            }
          ]
        },
        "benchDepth": {
          "allOf": [
            { "$ref": "#/$defs/claim" },
            {
              "properties": {
                "level": { "type": "string", "enum": ["deep", "moderate", "thin", "none"] },
                "byCapability": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["capability", "depth"],
                    "properties": {
                      "capability": { "type": "string" },
                      "depth": { "type": "string", "enum": ["deep", "moderate", "thin", "partner_only"] }
                    }
                  }
                }
              }
            }
          ]
        },
        "mobilisationSpeed": {
          "allOf": [
            { "$ref": "#/$defs/claim" },
            {
              "properties": {
                "typicalWeeksToStartAtScale": { "type": "number" },
                "confidenceAtScale": { "type": "string", "enum": ["high", "medium", "low"] }
              }
            }
          ]
        },
        "transitionCapability": {
          "allOf": [
            { "$ref": "#/$defs/claim" },
            {
              "properties": {
                "level": { "type": "string", "enum": ["strong", "adequate", "weak", "untested"] },
                "description": { "type": "string" }
              }
            }
          ]
        },
        "associateModel": {
          "type": "object",
          "properties": {
            "used": { "type": "boolean" },
            "percentOfDeliveryApprox": { "type": "number", "minimum": 0, "maximum": 100 },
            "riskNotes": { "type": "string" }
          }
        },
        "subcontractorDependence": {
          "allOf": [
            { "$ref": "#/$defs/claim" },
            {
              "properties": {
                "level": { "type": "string", "enum": ["high", "moderate", "low", "none"] },
                "namedCriticalPartners": { "type": "array", "items": { "type": "string" } }
              }
            }
          ]
        },
        "overcommitmentHistory": {
          "type": "array",
          "items": { "$ref": "#/$defs/claim" },
          "description": "Past instances where promises exceeded delivery capacity — high-value for AI to avoid recommending the same shapes"
        }
      }
    },

    "cultureDecisionStyle": {
      "type": "object",
      "description": "The human layer — calibrates how hard AI pushes back, what tone to use, and what strategy ambition the client will actually accept.",
      "properties": {
        "appetiteForChallenge": {
          "allOf": [
            { "$ref": "#/$defs/claim" },
            {
              "properties": {
                "level": { "type": "string", "enum": ["direct_and_forceful", "reasoned_but_firm", "suggestive_only", "avoid_conflict"] }
              },
              "required": ["level"]
            }
          ]
        },
        "boldVsSafePositioning": {
          "allOf": [
            { "$ref": "#/$defs/claim" },
            {
              "properties": {
                "level": { "type": "string", "enum": ["bold", "balanced", "safe"] }
              },
              "required": ["level"]
            }
          ]
        },
        "decisionSpeed": {
          "allOf": [
            { "$ref": "#/$defs/claim" },
            {
              "properties": {
                "pattern": { "type": "string", "enum": ["same_day", "same_week", "formal_governance_cycle", "variable"] }
              },
              "required": ["pattern"]
            }
          ]
        },
        "tonePreferences": {
          "type": "object",
          "properties": {
            "preferredRegister": { "type": "string", "enum": ["plain_english", "professional", "formal", "consultative"] },
            "avoidTerms": { "type": "array", "items": { "type": "string" } },
            "preferTerms": { "type": "array", "items": { "type": "string" } },
            "notes": { "type": "string" }
          }
        },
        "internalPolitics": {
          "type": "array",
          "items": { "$ref": "#/$defs/claim" },
          "description": "Sales vs delivery tensions, leadership fault lines, BU-level incentive conflicts — the AI should know what not to reopen"
        },
        "qualityExpectations": {
          "allOf": [
            { "$ref": "#/$defs/claim" },
            {
              "properties": {
                "level": { "type": "string", "enum": ["high", "moderate", "pragmatic", "variable"] },
                "description": { "type": "string" }
              }
            }
          ]
        },
        "ambiguityTolerance": {
          "allOf": [
            { "$ref": "#/$defs/claim" },
            {
              "properties": {
                "level": { "type": "string", "enum": ["high", "medium", "low"] }
              }
            }
          ]
        }
      }
    },

    "sources": {
      "type": "array",
      "description": "Every claim should reference one or more sources here by sourceId",
      "items": {
        "type": "object",
        "required": ["sourceId", "sourceType", "date"],
        "properties": {
          "sourceId": { "type": "string" },
          "sourceType": {
            "type": "string",
            "enum": [
              "client_interview",
              "crm",
              "financial_report",
              "proposal_archive",
              "delivery_review",
              "leadership_workshop",
              "market_analysis",
              "internal_document",
              "manual_entry"
            ]
          },
          "title": { "type": "string" },
          "date": { "type": "string", "format": "date" },
          "sourceQuality": { "type": "string", "enum": ["high", "medium", "low"] },
          "owner": { "type": "string" },
          "confidentiality": { "type": "string", "enum": ["internal", "client_confidential", "restricted"] }
        }
      }
    }
  },

  "$defs": {
    "claimType": {
      "type": "string",
      "enum": ["fact", "interpretation", "assumption", "hypothesis", "unknown"],
      "description": "fact: verifiable and verified. interpretation: reasoned from evidence. assumption: working premise, unverified. hypothesis: to be tested. unknown: explicitly gapped."
    },
    "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
    "priorityLevel": { "type": "string", "enum": ["high", "medium", "low"] },
    "strengthLevel": { "type": "string", "enum": ["high", "medium", "low"] },
    "sourceRefs": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Array of sourceId values from the top-level sources array"
    },
    "claim": {
      "type": "object",
      "description": "A typed statement with provenance. Every meaningful content field uses this shape.",
      "required": ["claimType", "confidence"],
      "properties": {
        "statement": { "type": "string" },
        "value": {},
        "claimType": { "$ref": "#/$defs/claimType" },
        "confidence": { "$ref": "#/$defs/confidence" },
        "materiality": { "type": "string", "enum": ["high", "medium", "low"] },
        "lastVerifiedAt": { "type": "string", "format": "date" },
        "decayAfterDays": { "type": "integer", "description": "After this many days since lastVerifiedAt, treat as stale" },
        "sources": { "$ref": "#/$defs/sourceRefs" },
        "owner": { "type": "string" },
        "usagePermission": { "type": "string", "enum": ["external_ok", "internal_only", "needs_client_approval"] }
      }
    },
    "capabilityEntry": {
      "allOf": [
        { "$ref": "#/$defs/claim" },
        {
          "type": "object",
          "required": ["name", "strengthLevel"],
          "properties": {
            "name": { "type": "string" },
            "strengthLevel": { "$ref": "#/$defs/strengthLevel" },
            "evidenceProofIds": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Cross-reference to differentiation.proofPoints[].proofId"
            }
          }
        }
      ]
    }
  }
}

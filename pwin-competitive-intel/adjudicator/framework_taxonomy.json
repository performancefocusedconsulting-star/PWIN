      "lots": [
        {
          "lot_id": "DSP-L1",
          "lot_name": "Digital Specialists",
          "description": "Individual specialist contractors for specific digital roles. Buyers recruit named individuals or small teams for defined roles, typically time-and-materials.",
          "typical_examples": ["software developer", "data engineer", "UX researcher", "product manager", "cloud architect", "security analyst", "business analyst", "data scientist", "DevOps engineer"],

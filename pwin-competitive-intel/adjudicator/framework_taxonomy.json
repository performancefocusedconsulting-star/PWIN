        {
          "lot_id": "DSP-L2",
          "lot_name": "Digital Outcomes",
          "description": "Defined digital deliverables with clear outputs. The supplier is responsible for the outcome, not just supplying hours. Typically bounded phases with defined acceptance criteria.",
          "typical_examples": ["discovery phase", "alpha or beta service build", "data platform build", "API development", "accessibility audit and remediation", "service prototype", "technical spike"],
          "typical_value_band": "£20k–£5m",
          "buyer_archetypes": ["department", "agency", "nhs_trust", "local_authority"],
          "exclusions": ["Multi-year managed services (Lot 3)", "Individual specialist supply (Lot 1)"]
        },
        {
          "lot_id": "DSP-L3",
          "lot_name": "Digital Programmes",
          "description": "End-to-end programme delivery including multiple phases, release trains, or sustained delivery capacity. Complex, multi-year digital transformation programmes requiring blended teams.",
          "typical_examples": ["digital transformation programme", "legacy system replacement", "multi-year agile development contract", "enterprise digital delivery", "whole-organisation digital change"],
          "typical_value_band": "£500k–£50m",
          "buyer_archetypes": ["department", "agency", "nhs_trust", "local_authority", "mod"],
          "exclusions": ["Single specialist supply (Lot 1)", "Single defined output (Lot 2)", "SaaS products (see G-Cloud Lot 2)"]

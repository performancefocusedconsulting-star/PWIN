{
  "_meta": {
    "version": "0.1",
    "created": "2026-04-22",
    "purpose": "Classification vocabulary for Morgan Ledger. When classifying an off-framework award, only assign a lot_id that exists in this file. If no lot fits at confidence >= 0.70, leave the award unclassified.",
    "coverage": "5 high-usage CCS frameworks — G-Cloud 14, MCF4, DSP, TePAS 2, BPS3. Expand in v0.2 to include FM, Legal Services, and construction/infrastructure frameworks.",
    "rm_number_note": "RM numbers are best-available from public CCS publications. Verify against https://www.crowncommercial.gov.uk/agreements before treating as authoritative."
  },
  "frameworks": [
    {
      "framework_id": "GC14",
      "framework_rm": "RM1557.14",
      "framework_name": "G-Cloud 14",
      "lots": [
        {
          "lot_id": "GC14-L1",
          "lot_name": "Cloud Hosting",
          "description": "Infrastructure as a Service (IaaS) and Platform as a Service (PaaS) cloud computing resources, including virtual machines, containers, storage, databases, and associated infrastructure.",
          "typical_examples": ["AWS EC2/ECS hosting", "Azure virtual machines", "Google Cloud PaaS", "managed Kubernetes", "cloud object storage", "CDN services", "cloud databases"],
          "typical_value_band": "£10k–£10m",
          "buyer_archetypes": ["department", "agency", "nhs_trust", "local_authority"],
          "exclusions": ["SaaS applications (Lot 2)", "Support and migration services (Lot 3)", "End-user computing hardware"]
        },
        {
          "lot_id": "GC14-L2",
          "lot_name": "Cloud Software",
          "description": "Software as a Service (SaaS) applications delivered via the cloud. Pre-built, configurable software products accessed via browser or API — not bespoke development.",
          "typical_examples": ["CRM systems", "collaboration and productivity tools", "document management", "HR and payroll SaaS", "financial management systems", "case management platforms", "analytics and BI tools", "cyber security SaaS"],
          "typical_value_band": "£5k–£5m",
          "buyer_archetypes": ["department", "agency", "nhs_trust", "local_authority", "ndpb"],
          "exclusions": ["Bespoke software development (see DSP)", "Physical hardware", "Cloud infrastructure (Lot 1)"]
        },
        {
          "lot_id": "GC14-L3",
          "lot_name": "Cloud Support",
          "description": "Services to support planning, transitioning, operating and improving cloud-hosted services. Includes cloud migration, managed cloud operations, cloud architecture consulting, and specialist cloud support.",
          "typical_examples": ["cloud migration", "DevOps and site reliability engineering", "managed security operations (SOC)", "cloud architecture consulting", "disaster recovery as a service", "FinOps/cloud cost optimisation", "cloud assurance and testing"],
          "typical_value_band": "£10k–£10m",
          "buyer_archetypes": ["department", "agency", "nhs_trust", "local_authority"],
          "exclusions": ["Physical infrastructure", "Non-cloud IT support (see TePAS2)", "Software products (Lot 2)"]
        }
      ]
    },
